VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
VITE_PUBLIC_BASE=/

# Smart ID backend used by the Vite dev proxy.
VITE_SMART_ID_TARGET=http://precis-agric.tsg.cfpamf.com

# Comma-separated hostnames that are allowed to visit the Vite dev server.
# Example: localhost,127.0.0.1,flow.test.local
# Leave empty to allow any host in development.
VITE_ALLOWED_HOSTS=

# Fill these only when you access the app through a reverse proxy/domain and
# hot reload websocket cannot connect back.
# Example:
# VITE_HMR_PROTOCOL=ws
# VITE_HMR_HOST=flow.test.local
# VITE_HMR_PORT=5173
VITE_HMR_PROTOCOL=
VITE_HMR_HOST=
VITE_HMR_PORT=
